{
    "version": "2.0.0",
    "tasks": [
        // ─── CHẠY NHANH (smoke) ───────────────────────────────────────────────
        {
            "label": "k6: smoke – showtime-get",
            "type": "shell",
            "command": "k6 run --env SCENARIO=smoke tests/showtime-get.test.js",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "k6: smoke – showtime-flow",
            "type": "shell",
            "command": "k6 run --env SCENARIO=smoke tests/showtime-flow.test.js",
