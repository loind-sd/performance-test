        // ─── LOAD / STRESS ────────────────────────────────────────────────────
        {
            "label": "k6: load – showtime-get",
            "type": "shell",
            "command": "k6 run --env SCENARIO=load tests/showtime-get.test.js",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "k6: stress – showtime-get",
            "type": "shell",
            "command": "k6 run --env SCENARIO=stress tests/showtime-get.test.js",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },

        // ─── CUSTOM CREDENTIALS ───────────────────────────────────────────────
        {
            "label": "k6: smoke – custom credentials",
            "type": "shell",
            "command": "k6 run --env SCENARIO=smoke --env AUTH_USERNAME=${input:username} --env AUTH_PASSWORD=${input:password} tests/showtime-get.test.js",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        }
    ],
    "inputs": [
        {
            "id": "username",
            "type": "promptString",
            "description": "Auth username",
            "default": "user1@cinema.com"
        },
        {
            "id": "password",
            "type": "promptString",
            "description": "Auth password",
            "password": true,
            "default": "password123"
        }
    ]
}
