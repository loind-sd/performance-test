        // ─── DEBUG (1 VU, verbose + http-debug) ──────────────────────────────
        {
            "label": "k6: DEBUG – file hiện tại (1 VU, 30s)",
            "type": "shell",
            "command": "k6 run --vus 1 --duration 5s --http-debug=full --verbose ${relativeFile}",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "k6: DEBUG – showtime-get (http-debug)",
            "type": "shell",
            "command": "k6 run --vus 1 --duration 5s --http-debug=full tests/showtime-get.test.js",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "k6: DEBUG – booking-flow (http-debug)",
            "type": "shell",
            "command": "k6 run --vus 1 --duration 30s --http-debug=full tests/booking-flow.test.js",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },

        // ─── ORDER FLOW ───────────────────────────────────────────────────────
        {
            "label": "k6: smoke – order-flow",
            "type": "shell",
            "command": "k6 run --env SCENARIO=smoke tests/order-flow.test.js",
